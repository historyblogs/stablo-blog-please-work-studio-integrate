---
import type { GetStaticPaths } from 'astro';
import type { ImageMetadata } from 'astro';
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import { findImage } from '~/utils/images';
import { cleanSlug } from '~/utils/permalinks';

export const prerender = true;

export const getStaticPaths = (async () => {
  const allPosts = await getCollection('post');
  const draftPosts = allPosts.filter((p) => p.data.draft);

  return await Promise.all(
    draftPosts.map(async (post) => {
      const slug = cleanSlug(post.id);
      return { params: { slug } };
    })
  );
}) satisfies GetStaticPaths;

const { slug } = Astro.params;

const allPosts = await getCollection('post');
const entry = allPosts.find((p) => cleanSlug(p.id) === slug);

if (!entry) return Astro.redirect('/404');

const { Content } = await render(entry);

const {
  title,
  excerpt,
  image: rawImage,
  publishDate: rawPublishDate = new Date(),
  updateDate: rawUpdateDate,
  author,
  category: rawCategory,
  tags: rawTags = [],
  location: locationRef,
} = entry.data;

let location;
if (locationRef) {
  const locationEntry = await getEntry(locationRef);
  if (locationEntry) location = { ...locationEntry.data, slug: locationEntry.id };
}

const publishDate = new Date(rawPublishDate);
const updateDate = rawUpdateDate ? new Date(rawUpdateDate) : undefined;
const category = rawCategory ? { slug: rawCategory.toLowerCase().replace(/\s+/g, '-'), title: rawCategory } : undefined;
const tags = rawTags.map((t: string) => ({ slug: t.toLowerCase().replace(/\s+/g, '-'), title: t }));

const image = (await findImage(rawImage)) as ImageMetadata | string | undefined;

const post = {
  id: entry.id,
  slug,
  permalink: `preview/${slug}`,
  publishDate,
  updateDate,
  title,
  excerpt,
  image,
  category,
  tags,
  author,
  draft: true,
  metadata: {},
  location,
  Content,
  readingTime: undefined,
};

const metadata = {
  title: `DRAFT PREVIEW — ${title}`,
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <div class="bg-yellow-400 text-black text-center py-3 px-4 font-bold text-sm tracking-wide">
    DRAFT PREVIEW — This post is not live on the site.
    To publish it, open it in the editor and uncheck the Draft box.
  </div>
  <SinglePost post={post} url={new URL(`/preview/${slug}`, Astro.site)}>
    {Content && <Content />}
  </SinglePost>
  <ToBlogLink />
</Layout>

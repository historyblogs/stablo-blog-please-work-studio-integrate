---
import Layout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import { fetchPosts } from '~/utils/blog';
import { findImage } from '~/utils/images';
import { getPermalink } from '~/utils/permalinks';
import { APP_BLOG } from 'astrowind:config';

const POSTS_PER_PAGE = 20;

const allPosts = await fetchPosts();
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);

const images = await Promise.all(posts.map((post) => findImage(post.image)));

const metadata = {
  title: 'RIP Los Angeles',
  description: 'RIP Los Angeles blogs Los Angeles one demolition permit at a time.',
  ignoreTitleTemplate: true,
};

const SITE = 'https://www.riplosangeles.com';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'RIP Los Angeles',
  url: SITE,
  description: 'Blogging Los Angeles one demolition permit at a time.',
  author: {
    '@type': 'Person',
    name: 'Nathan Marsak',
    url: `${SITE}/about`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'RIP Los Angeles',
    url: SITE,
  },
  inLanguage: 'en-US',
  sameAs: ['https://twitter.com/riplosangeles'],
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <header class="text-center mb-10">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight font-heading dark:text-white">RIP Los Angeles</h1>
      <p class="mt-3 text-lg text-muted dark:text-slate-400">Blogging Los Angeles one demolition permit at a time.</p>
    </header>

    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-5">
      {
        posts.map((post, i) => {
          const image = images[i];
          const href = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
          return (
            <a href={href} class="group block">
              <div class="aspect-square overflow-hidden rounded bg-gray-200 dark:bg-slate-700 shadow-sm">
                {image ? (
                  <Image
                    src={image}
                    alt={post.title}
                    width={480}
                    height={480}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    widths={[240, 480]}
                    sizes="(max-width: 640px) calc(50vw - 24px), (max-width: 1024px) calc(33vw - 24px), 240px"
                    loading={i < 10 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="text-gray-400 text-xs text-center px-2">{post.title}</span>
                  </div>
                )}
              </div>
              <p class="mt-2 text-lg font-semibold leading-snug group-hover:text-primary dark:text-slate-300 dark:group-hover:text-blue-400 line-clamp-3 transition-colors duration-150">
                {post.title}
              </p>
            </a>
          );
        })
      }
    </div>

    {
      totalPages > 1 && (
        <nav class="flex justify-center items-center gap-3 mt-14" aria-label="Pagination">
          <span class="text-sm text-muted dark:text-slate-400">Page 1 of {totalPages}</span>
          <a
            href="/blog/2"
            class="inline-flex items-center gap-1 px-5 py-2 rounded border border-gray-300 dark:border-slate-600 text-sm font-medium hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors duration-150"
          >
            Older Posts
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path
                fill-rule="evenodd"
                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
        </nav>
      )
    }
  </section>
</Layout>

---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';
import { findImage } from '~/utils/images';
import type { ImageMetadata } from 'astro';

export const prerender = true;

export const getStaticPaths = (async () => {
  const locations = await getCollection('locations');
  return locations.map((loc) => ({
    params: { slug: loc.id },
    props: { location: loc },
  }));
}) satisfies GetStaticPaths;

const { location } = Astro.props;
const { title, address, lat, lng } = location.data;

const allPosts = await fetchPosts();
const posts = allPosts.filter((p) => p.location?.slug === location.id);

const hasCoords = lat !== undefined && lng !== undefined;
const embedQuery = hasCoords ? `${lat},${lng}` : encodeURIComponent(address);
const embedSrc = `https://maps.google.com/maps?q=${embedQuery}&output=embed&z=17`;
const mapsHref = hasCoords
  ? `https://www.google.com/maps?q=${lat},${lng}`
  : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;

const SITE = 'https://www.riplosangeles.com';
const canonicalUrl = `${SITE}/locations/${location.id}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: title,
  address: {
    '@type': 'PostalAddress',
    streetAddress: address.replace(/,\s*Los Angeles.*$/, '').trim(),
    addressLocality: 'Los Angeles',
    addressRegion: 'CA',
    addressCountry: 'US',
  },
  ...(hasCoords
    ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: lat,
          longitude: lng,
        },
      }
    : {}),
  url: canonicalUrl,
};

const metadata = {
  title,
  description: `${posts.length} ${posts.length === 1 ? 'post' : 'posts'} about ${address} on RIP Los Angeles.`,
  canonical: canonicalUrl,
};

// Pre-resolve hero images for each post
const postImages = await Promise.all(
  posts.map((p) => findImage(p.image))
);
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <!-- Header -->
    <div class="mb-2">
      <a
        href="/locations/"
        class="inline-flex items-center gap-1 text-sm text-muted hover:text-primary dark:text-slate-400 dark:hover:text-blue-400 transition-colors mb-4"
      >
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        All locations
      </a>
    </div>

    <div class="flex items-start gap-2 mb-1">
      <Icon name="tabler:map-pin" class="w-6 h-6 text-primary mt-1 shrink-0" />
      <h1 class="text-3xl md:text-4xl font-bold font-heading tracking-tight">{title}</h1>
    </div>
    <p class="text-muted dark:text-slate-400 text-sm mb-8 ml-8">{address}</p>

    <!-- Map embed -->
    <div class="rounded-lg overflow-hidden shadow-md mb-3">
      <iframe
        src={embedSrc}
        width="100%"
        height="380"
        style="border:0"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Map: ${address}`}
      ></iframe>
    </div>
    <a
      href={mapsHref}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 mb-10 text-xs text-muted hover:text-primary dark:text-slate-500 dark:hover:text-blue-400 transition-colors duration-150"
    >
      <Icon name="tabler:external-link" class="w-3.5 h-3.5" />
      View on Google Maps
    </a>

    <!-- Posts at this location -->
    <h2 class="text-xl font-bold font-heading mb-6">
      {posts.length === 1 ? '1 post' : `${posts.length} posts`} at this address
    </h2>

    {posts.length === 0 && (
      <p class="text-muted dark:text-slate-400">No posts found for this location.</p>
    )}

    <div class="grid gap-6 sm:grid-cols-2">
      {posts.map((post, i) => {
        const img = postImages[i] as ImageMetadata | string | undefined;
        const url = getPermalink(post.permalink, 'post');
        return (
          <article class="group border dark:border-slate-700 rounded-xl overflow-hidden hover:shadow-md transition-shadow duration-200">
            {img && (
              <a href={url} tabindex="-1" aria-hidden="true">
                <Image
                  src={img}
                  alt={post.excerpt ?? post.title}
                  width={600}
                  height={338}
                  widths={[300, 600]}
                  sizes="(max-width: 640px) 100vw, 300px"
                  format="webp"
                  class="w-full aspect-video object-cover"
                />
              </a>
            )}
            <div class="p-4">
              <p class="text-xs text-muted dark:text-slate-500 mb-1">
                {getFormattedDate(post.publishDate)}
              </p>
              <h3 class="font-semibold leading-snug mb-2">
                <a
                  href={url}
                  class="hover:text-primary dark:hover:text-blue-400 transition-colors duration-150"
                >
                  {post.title}
                </a>
              </h3>
              {post.excerpt && (
                <p class="text-sm text-muted dark:text-slate-400 line-clamp-2">{post.excerpt}</p>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</Layout>

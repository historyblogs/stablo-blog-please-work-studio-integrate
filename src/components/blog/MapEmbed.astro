---
import { Icon } from 'astro-icon/components';
import type { PostLocation } from '~/types';

export interface Props {
  location: PostLocation;
  locationSlug?: string;
}

const { location, locationSlug } = Astro.props;
const { address, lat, lng } = location;

const hasCoords = lat !== undefined && lng !== undefined;
const embedQuery = hasCoords ? `${lat},${lng}` : encodeURIComponent(address);
const embedSrc = `https://maps.google.com/maps?q=${embedQuery}&output=embed&z=17`;
const mapsHref = hasCoords
  ? `https://www.google.com/maps?q=${lat},${lng}`
  : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;
---

<div class="mt-10 pt-8 border-t dark:border-slate-700">
  <div class="flex items-center gap-2 mb-2">
    <Icon name="tabler:map-pin" class="w-5 h-5 text-primary shrink-0" />
    <h3 class="text-base font-semibold dark:text-slate-300">Location</h3>
  </div>
  <p class="text-sm text-muted dark:text-slate-400 mb-3">{address}</p>

  <div class="rounded-lg overflow-hidden shadow-md">
    <iframe
      src={embedSrc}
      width="100%"
      height="380"
      style="border:0"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title={`Map: ${address}`}
    ></iframe>
  </div>

  <div class="flex items-center gap-4 mt-2">
    <a
      href={mapsHref}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-xs text-muted hover:text-primary dark:text-slate-500 dark:hover:text-blue-400 transition-colors duration-150"
    >
      <Icon name="tabler:external-link" class="w-3.5 h-3.5" />
      View on Google Maps
    </a>
    {locationSlug && (
      <a
        href={`/locations/${locationSlug}/`}
        class="inline-flex items-center gap-1 text-xs text-muted hover:text-primary dark:text-slate-500 dark:hover:text-blue-400 transition-colors duration-150"
      >
        <Icon name="tabler:building" class="w-3.5 h-3.5" />
        Location hub
      </a>
    )}
  </div>
</div>
